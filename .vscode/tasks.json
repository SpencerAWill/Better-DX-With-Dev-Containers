{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "EF: Add Migration",
      "type": "shell",
      "command": "dotnet",
      "args": [
        "ef",
        "migrations",
        "add",
        "${input:migrationName}",
        "--project",
        "libs/data-migrations/Project.Data.Migrations.csproj",
        "--startup-project",
        "apps/webapi/Project.API.csproj"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "focus": true
      }
    },
    {
      "label": "EF: Update Database",
      "type": "shell",
      "command": "dotnet",
      "args": [
        "ef",
        "database",
        "update",
        "--project",
        "libs/data-migrations/Project.Data.Migrations.csproj",
        "--startup-project",
        "apps/webapi/Project.API.csproj"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "focus": true
      }
    },
    {
      "label": "EF: Remove Last Migration",
      "type": "shell",
      "command": "dotnet",
      "args": [
        "ef",
        "migrations",
        "remove",
        "--project",
        "libs/data-migrations/Project.Data.Migrations.csproj",
        "--startup-project",
        "apps/webapi/Project.API.csproj"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "focus": true
      }
    }
  ],
  "inputs": [
    {
      "id": "migrationName",
      "type": "promptString",
      "description": "Migration name (e.g. AddOrdersTable)"
    }
  ]
}
